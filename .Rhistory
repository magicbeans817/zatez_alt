# app.R — krok 1: založení třídy a export rosteru do CSV
# ------------------------------------------------------
library(shiny)
library(bslib)
library(DT)
library(tidyverse)   # kvůli stringr/dplyr/readr (můžeš zúžit dle chuti)
# --- pomocné: validace emailu a seznamu ---
is_valid_email <- function(x) {
grepl("^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$", x)
}
validate_roster <- function(df) {
df <- df %>%
mutate(
nickname = stringr::str_squish(as.character(nickname)),
email    = stringr::str_squish(as.character(email))
) %>%
dplyr::filter(nickname != "" | email != "")  # vyhoď úplně prázdné řádky
if (nrow(df) == 0) return(list(ok = FALSE, msg = "Seznam je prázdný."))
if (any(df$nickname == "" | df$email == "")) {
return(list(ok = FALSE, msg = "Vyplň prosím oba sloupce u všech řádků (nickname i email)."))
}
if (any(!is_valid_email(df$email))) {
bad <- df$email[!is_valid_email(df$email)]
return(list(ok = FALSE, msg = paste0("Neplatné emaily: ", paste(unique(bad), collapse = ", "))))
}
if (any(duplicated(tolower(df$nickname)))) {
dups <- df$nickname[duplicated(tolower(df$nickname))]
return(list(ok = FALSE, msg = paste0("Duplicitní přezdívky: ", paste(unique(dups), collapse = ", "))))
}
if (any(duplicated(tolower(df$email)))) {
dups <- df$email[duplicated(tolower(df$email))]
return(list(ok = FALSE, msg = paste0("Duplicitní emaily: ", paste(unique(dups), collapse = ", "))))
}
if (nrow(df) < 3) {
return(list(ok = FALSE, msg = "Je potřeba aspoň 3 účastníci."))
}
list(ok = TRUE, data = df)
}
# --- UI ---
ui <- fluidPage(
theme = bs_theme(version = 5, bootswatch = "darkly"),
tags$head(
# malý JS handler, který pošle „klik“ na skryté download tlačítko
tags$script(HTML("
Shiny.addCustomMessageHandler('trigger-download', function(id){
var el = document.getElementById(id);
if (el) el.click();
});
"))
),
titlePanel("Sociomapování — založit novou třídu"),
# 1) start: velké tlačítko
div(
style = "margin: 20px 0;",
actionButton("new_class_btn", "Vytvoř novou třídu a rozešli dotazníky",
class = "btn btn-primary btn-lg")
),
# 2) po potvrzení názvu třídy se sem vyrenderuje editor
uiOutput("builder_ui")
)
# --- SERVER ---
server <- function(input, output, session) {
class_name <- reactiveVal(NULL)                 # uloží název třídy
roster_rv  <- reactiveVal(tibble(nickname = rep("", 30),
email    = rep("", 30)))
csv_path_rv <- reactiveVal(NULL)                # cesta k vygenerovanému CSV
# klik na „Vytvoř novou třídu…“ → modal s názvem
observeEvent(input$new_class_btn, {
showModal(modalDialog(
title = "Zadej název třídy",
textInput("class_name_input", "Název třídy", placeholder = "např. 3.A 2025/26"),
footer = tagList(
modalButton("Zrušit"),
actionButton("confirm_class", "Potvrdit", class = "btn btn-success")
),
easyClose = TRUE
))
})
# potvrzení názvu třídy
observeEvent(input$confirm_class, {
nm <- stringr::str_squish(input$class_name_input %||% "")
if (!nzchar(nm)) {
showNotification("Název třídy nemůže být prázdný.", type = "error")
return()
}
class_name(nm)
removeModal()
})
# bezpečné jméno pro soubor
safe_class <- reactive({
req(class_name())
gsub("[^A-Za-z0-9_-]+", "_", class_name())
})
# UI editoru rosteru (zobraz až po pojmenování třídy)
output$builder_ui <- renderUI({
req(class_name())
tagList(
h4(HTML(sprintf("Třída: <code>%s</code>", htmltools::htmlEscape(class_name())))),
p("Vyplň sloupce ", code("nickname"), " a ", code("email"), "."),
div(
class = "mb-2",
actionButton("add_row", "Přidat řádek"),
actionButton("del_row", "Smazat vybraný", class = "ms-2")
),
DTOutput("roster_tbl"),
div(class = "mt-3",
actionButton("vyplneno", "Vyplněno", class = "btn btn-success")
),
# skryté download tlačítko; spustíme ho programově po validaci
tags$div(style = "display:none;",
downloadButton("dl_roster_csv", "Stáhnout CSV"))
)
})
# DataTable render + editace
output$roster_tbl <- renderDT({
datatable(
roster_rv(),
rownames = FALSE,
editable = "cell",
selection = "single",
options = list(dom = "t", pageLength = 30)
)
})
proxy <- dataTableProxy("roster_tbl")
observeEvent(input$roster_tbl_cell_edit, {
info <- input$roster_tbl_cell_edit
dat  <- roster_rv()
r <- info$row; c <- info$col; v <- info$value
if (!is.null(r) && !is.null(c)) {
dat[r, c] <- as.character(v)
roster_rv(dat)
replaceData(proxy, dat, resetPaging = FALSE, rownames = FALSE)
}
})
observeEvent(input$add_row, {
dat <- roster_rv() %>% add_row(nickname = "", email = "")
roster_rv(dat)
replaceData(proxy, dat, resetPaging = FALSE, rownames = FALSE)
})
observeEvent(input$del_row, {
s <- input$roster_tbl_rows_selected
if (length(s) == 1) {
dat <- roster_rv()[-s, , drop = FALSE]
roster_rv(dat)
replaceData(proxy, dat, resetPaging = FALSE, rownames = FALSE)
} else {
showNotification("Vyber přesně jeden řádek ke smazání.", type = "warning")
}
})
# „Vyplněno“ → validace + auto-download CSV
observeEvent(input$vyplneno, {
val <- validate_roster(roster_rv())
if (!isTRUE(val$ok)) {
showNotification(val$msg, type = "error", duration = 6)
return()
}
# ulož do dočasného CSV a rozjeď download
tmp <- tempfile(paste0("tricet_jmen_", safe_class(), "_"), fileext = ".csv")
readr::write_csv(val$data, tmp)
csv_path_rv(tmp)
# programově „klikni“ na skryté download tlačítko
session$sendCustomMessage("trigger-download", "dl_roster_csv")
showNotification("CSV připraveno ke stažení.", type = "message")
})
# obsah downloadu
output$dl_roster_csv <- downloadHandler(
filename = function() sprintf("%s_tricet_jmen.csv", safe_class()),
content  = function(file) {
req(csv_path_rv())
file.copy(csv_path_rv(), file, overwrite = TRUE)
}
)
}
shinyApp(ui, server)
