# app.R
library(shiny)
library(tidyverse)
library(ggplot2)
library(ggrepel)
library(viridis)
library(ggforce)
library(smacof)
library(fields)
# ---------- OPRAVENÁ FUNKCE ----------
vytvor_mapu <- function(data,
sloupec_vzdalenost = "Interaction_Level",
sloupec_teplota    = "Interaction_Level",
smer               = c("ke","od"),
seed               = 42,
sipky              = c("desired>interaction",
"desired<interaction",
"prijemnost_komunikace==1",
"zadne"),
arrow_shrink       = 0.1,
nazev_teploty      = "Průměrná přijatá hodnota") {
stopifnot(is.data.frame(data))
smer  <- match.arg(smer)
sipky <- match.arg(sipky)
set.seed(seed)
# --- seznam jmen (robustně: sjednocení obou sloupců) ---
if (!all(c("Respondent","Target") %in% names(data))) {
stop("Data musí obsahovat sloupce 'Respondent' a 'Target'.")
}
students <- sort(unique(c(as.character(data$Respondent),
as.character(data$Target))))
n <- length(students)
if (n < 2) stop("Potřeba aspoň dva různí studenti.")
# Pomocná funkce: z daného sloupce (název) udělej čtvercovou matici
make_matrix <- function(sloupec) {
if (!sloupec %in% names(data)) {
stop(sprintf("Sloupec '%s' v datech neexistuje.", sloupec))
}
M <- matrix(0, n, n, dimnames = list(students, students))
# mapování indexů (rychlé a bezpečné)
ri <- match(as.character(data$Respondent), students)
ti <- match(as.character(data$Target),     students)
vals <- data[[sloupec]]
ok <- !is.na(ri) & !is.na(ti) & !is.na(vals)
M[cbind(ri[ok], ti[ok])] <- vals[ok]
M
}
# --- matice pro vzdálenosti a pro "teplotu" ---
interaction_matrix_vzd <- make_matrix(sloupec_vzdalenost)
interaction_matrix_tep <- make_matrix(sloupec_teplota)
# symetrizace a převod na vzdálenosti (větší hodnota = blíž → tady 5 - průměr)
distance_matrix <- 5 - (interaction_matrix_vzd + t(interaction_matrix_vzd)) / 2
# MDS
mds_result <- smacof::smacofSym(distance_matrix, type = "interval", ndim = 2)
mds_coords <- mds_result$conf
colnames(mds_coords) <- c("x", "y")
# průměrné interakce (pro "teplotu" bodů i podkladu)
if (smer == "ke") {
average_interactions <- colSums(interaction_matrix_tep) / pmax(n - 1, 1)
} else {
average_interactions <- rowSums(interaction_matrix_tep) / pmax(n - 1, 1)
}
# Grid + interpolace
grid <- expand.grid(
x = seq(min(mds_coords[,1]) - 0.2, max(mds_coords[,1]) + 0.2, length.out = 300),
y = seq(min(mds_coords[,2]) - 0.2, max(mds_coords[,2]) + 0.2, length.out = 300)
)
interp_data <- data.frame(
x = mds_coords[,1],
y = mds_coords[,2],
z = as.numeric(average_interactions)
)
interp_func <- fields::Tps(interp_data[,1:2], interp_data$z)
grid$z <- predict(interp_func, as.matrix(grid[, c("x", "y")]))
coords_df <- tibble::tibble(
student = students,
x = mds_coords[,1],
y = mds_coords[,2],
average_interactions = as.numeric(average_interactions)
)
# --- Šipky (bezpečná inicializace prázdné df) ---
arrows <- tibble::tibble(x = numeric(), y = numeric(),
xend = numeric(), yend = numeric())
if (sipky != "zadne") {
desired_matrix     <- make_matrix("Desired_Communication")
actual_matrix      <- make_matrix("Interaction_Level")
prijemnost_matrix  <- if ("Prijemnost_Komunikace" %in% names(data)) make_matrix("Prijemnost_Komunikace") else NULL
add_arrows <- function(A, B, pred) {
out <- tibble::tibble(x = numeric(), y = numeric(),
xend = numeric(), yend = numeric())
for (i in seq_len(n)) {
for (j in seq_len(n)) {
if (i != j && pred(A[i,j], B[i,j])) {
xi <- mds_coords[i,1]; yi <- mds_coords[i,2]
xj <- mds_coords[j,1]; yj <- mds_coords[j,2]
dx <- xj - xi; dy <- yj - yi
d  <- sqrt(dx^2 + dy^2)
if (d > 0) {
out <- dplyr::bind_rows(out, tibble::tibble(
x = xi, y = yi,
xend = xi + dx * (1 - arrow_shrink / d),
yend = yi + dy * (1 - arrow_shrink / d)
))
}
}
}
}
out
}
if (sipky == "desired>interaction") {
arrows <- add_arrows(desired_matrix, actual_matrix, function(a,b) a > b)
} else if (sipky == "desired<interaction") {
arrows <- add_arrows(actual_matrix, desired_matrix, function(a,b) a > b)
} else if (sipky == "prijemnost_komunikace==1" && !is.null(prijemnost_matrix)) {
arrows <- add_arrows(prijemnost_matrix, prijemnost_matrix, function(a, b) isTRUE(a == 1))
}
}
# --- GRAF ---
g <- ggplot() +
geom_raster(data = grid, aes(x = x, y = y, fill = z), interpolate = TRUE) +
geom_contour(data = grid, aes(x = x, y = y, z = z),
color = "grey30", linewidth = 0.4, bins = 15) +
scale_fill_viridis(option = "C", name = nazev_teploty, direction = 1) +
geom_point(data = coords_df,
aes(x = x, y = y, color = average_interactions),
size = 6, shape = 21, stroke = 1.2) +
scale_color_viridis(option = "C", name = if (smer=="ke") "Průměr přijímaný (ke)" else "Průměr odesílaný (od)") +
geom_text_repel(data = coords_df, aes(x = x, y = y, label = student), size = 3.5) +
theme_void() +
coord_fixed() +
ggtitle("Sociomapování: Spojitá mapa interakcí") +
theme(plot.title = element_text(hjust = 0.5))
if (nrow(arrows) > 0) {
col <- dplyr::case_when(
sipky == "desired>interaction" ~ "red",
sipky == "desired<interaction" ~ "blue",
sipky == "prijemnost_komunikace==1" ~ "gold",
TRUE ~ "black"
)
g <- g + geom_segment(data = arrows, aes(x = x, y = y, xend = xend, yend = yend),
arrow = arrow(length = unit(0.2, "cm"), type = "closed"),
color = col, alpha = 0.7, linewidth = 0.7)
}
return(g)
}
# ---------- SHINY UI ----------
ui <- fluidPage(
titlePanel("Sociomapování – Shiny"),
sidebarLayout(
sidebarPanel(
fileInput("file", "Nahraj CSV", accept = c(".csv")),
selectInput("sl_vzd", "Sloupec pro MDS vzdálenosti",
choices = c("Interaction_Level","Desired_Communication","Prijemnost_Komunikace"),
selected = "Interaction_Level"),
selectInput("sl_tep", "Sloupec pro teplotu",
choices = c("Interaction_Level","Desired_Communication","Prijemnost_Komunikace"),
selected = "Interaction_Level"),
radioButtons("smer", "Směr průměru", choices = c("ke","od"), selected = "ke", inline = TRUE),
selectInput("sipky", "Šipky",
choices = c("desired>interaction","desired<interaction","prijemnost_komunikace==1","zadne"),
selected = "desired>interaction"),
sliderInput("shrink", "Zkrácení šipky (arrow_shrink)", min = 0, max = 0.8, value = 0.1, step = 0.02),
textInput("nazev", "Název legendy (teplota)", value = "Průměrná přijatá hodnota"),
actionButton("vykresli", "Vykreslit", class = "btn-primary")
),
mainPanel(
plotOutput("plot", height = "800px")
)
)
)
# ---------- SHINY SERVER ----------
server <- function(input, output, session) {
df <- reactive({
req(input$file)
readr::read_csv(input$file$datapath, show_col_types = FALSE) %>%
mutate(
Respondent = as.character(Respondent),
Target     = as.character(Target)
)
})
graf_reactive <- eventReactive(input$vykresli, {
d <- df()
validate(
need(all(c("Respondent","Target") %in% names(d)), "V CSV chybí sloupce Respondent/Target.")
)
# doporučení: přítomnost číselných sloupců
for (nm in unique(c(input$sl_vzd, input$sl_tep, "Interaction_Level","Desired_Communication"))) {
if (nm %in% names(d)) d[[nm]] <- suppressWarnings(as.numeric(d[[nm]]))
}
vytvor_mapu(
data = d,
sloupec_vzdalenost = input$sl_vzd,
sloupec_teplota    = input$sl_tep,
smer               = input$smer,
seed               = 42,
sipky              = input$sipky,
arrow_shrink       = input$shrink,
nazev_teploty      = input$nazev
)
}, ignoreInit = TRUE)
output$plot <- renderPlot({
req(graf_reactive())
graf_reactive()
})
}
shinyApp(ui, server)
runApp('shiny.R')
